<Window x:Class="VAR1_Demo_exam.Views.ManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Окно менеджера" Height="620" Width="980" WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Личный кабинет менеджера" FontSize="20" FontWeight="Bold" />

        <TabControl Grid.Row="1" Margin="0,10,0,10">
            <TabItem Header="Профиль">
                <StackPanel Margin="10">
                    <TextBlock x:Name="ProfileTextBlock" Margin="0,0,0,8"/>
                    <Button Width="220" Height="32" Content="Изменить профиль" Click="EditProfile_Click"/>
                </StackPanel>
            </TabItem>
            <TabItem Header="Пользователи">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBox x:Name="SearchTextBox"
                             Height="28"
                             Margin="0,0,0,8"
                             VerticalContentAlignment="Center"
                             TextChanged="SearchTextBox_TextChanged"/>
                    <DataGrid Grid.Row="1"
                              x:Name="UsersGrid"
                              AutoGenerateColumns="True"
                              IsReadOnly="True"/>
                </Grid>
            </TabItem>
            <TabItem Header="Заказы">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <DataGrid x:Name="OrdersGrid"
                              AutoGenerateColumns="True"
                              IsReadOnly="True"/>
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,8,0,0">
                        <Button Width="180" Height="30" Content="Назначить перевозчика" Click="AssignCarrier_Click"/>
                        <Button Width="140" Height="30" Margin="8,0,0,0" Content="Обновить" Click="ReloadOrders_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl>

        <Button Grid.Row="2" Width="140" Height="30" Content="Выход" HorizontalAlignment="Right" Click="Logout_Click"/>
    </Grid>
</Window>
