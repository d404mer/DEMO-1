<Window x:Class="VAR1_Demo_exam.Views.ProducerConsumerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Окно производителя/потребителя" Height="600" Width="920" WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Личный кабинет производителя/потребителя" FontSize="20" FontWeight="Bold"/>
        <TextBlock Grid.Row="1" x:Name="ProfileTextBlock" Margin="0,8,0,8"/>

        <DataGrid Grid.Row="2"
                  x:Name="OrdersGrid"
                  AutoGenerateColumns="True"
                  IsReadOnly="True"/>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Width="170" Height="30" Content="Изменить профиль" Click="EditProfile_Click"/>
            <Button Width="150" Height="30" Margin="8,0,0,0" Content="Новая заявка" Click="NewOrder_Click"/>
            <Button Width="110" Height="30" Margin="8,0,0,0" Content="Обновить" Click="Reload_Click"/>
            <Button Width="110" Height="30" Margin="8,0,0,0" Content="Назад" Click="Back_Click"/>
        </StackPanel>
    </Grid>
</Window>
